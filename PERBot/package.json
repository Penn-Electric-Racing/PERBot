{
  "name": "perbot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "start": "node --enable-source-maps dist/app.js",
    "start:cloud": "node scripts-run-cloud.mjs",
    "build": "tsc -p tsconfig.json",
    "index": "tsx src/indexer.ts",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@notionhq/client": "^5.11.1",
    "@slack/bolt": "^4.2.0",
    "dotenv": "^16.6.1",
    "openai": "^6.7.0"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
