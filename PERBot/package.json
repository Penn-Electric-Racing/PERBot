{
  "name": "perbot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "start": "node --enable-source-maps dist/app.js",
    "start:cloud": "node scripts-run-cloud.mjs",
    "build": "tsc -p tsconfig.json",
    "index": "tsx src/indexer.ts",
    "enrich": "tsx src/sponsorship/enrichCli.ts",
    "draft": "tsx src/sponsorship/draftCli.ts",
    "find": "tsx src/sponsorship/discoveryCli.ts find",
    "scout": "tsx src/sponsorship/discoveryCli.ts scout",
    "job:sponsor-win": "tsx src/sponsorship/jobs/winPost.ts",
    "job:sponsor-stale": "tsx src/sponsorship/jobs/staleDm.ts",
    "job:sponsor-reply": "tsx src/sponsorship/jobs/replyDm.ts",
    "job:sponsor-digest": "tsx src/sponsorship/jobs/weeklyDigest.ts",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@notionhq/client": "^5.22.0",
    "@slack/bolt": "^4.2.0",
    "@slack/web-api": "^7.16.0",
    "dotenv": "^16.6.1",
    "openai": "^6.7.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "tsx": "^4.22.3",
    "typescript": "^5.9.2"
  }
}
